@article{closeSubs,
  title={When Lottery Losers Still Win: Magnet Schools with Close Substitutes},
  author={Bruhn, Jesse and Campos, Christopher and Chyn, Eric and Shrivatsa, Ishira},
  journal={Draft available upon request},
  abstract={Large urban districts have responded to growing pressure from charter schools and vouchers by expanding magnet school offerings as a district-run choice option. Do such specialized magnet programs generate meaningful academic benefits for their students? We provide new evidence on the effects of magnet programs by exploiting hundreds of randomized admission lotteries for oversubscribed magnets serving tens of thousands of applicants in the Los Angeles Unified School District (LAUSD). A standard lottery-based comparison of winners and losers provides no evidence that magnet schools raise standardized achievement in math and reading. However, the interpretation of these results is challenged by a substantial share of students attending other under-subscribed magnet programs when they lose a lottery. Evidence from both reduced form and semi-parametric selection models that account for this substitution suggests that magnet programs have substantial impacts. Our preferred estimates indicate that attending either an oversubscribed or under-subscribed magnet increases test scores by 0.30 to 0.45 standard deviations relative to the counterfactual of attending a traditional LAUSD school. However, we also find substantial program-level heterogeneity. Motivated by this, we characterize the joint distribution of causal effects on Math, ELA, and non-cognitive skills and use it to identify exceptional schools: those with a high-likelihood of jointly being the top 10\% of all three outcomes. Finally, combining achievement impacts with detailed school budget data reveals that investments in magnet programs pay for themselves, with marginal value of public funds estimates well above one. Overall, these results imply that recent and current efforts to expand magnet programs across U.S. school districts are likely to generate substantively large gains in student achievement and are cost effective.},
  selected={true}
}

@article{aiDiffusion,
  title={The AI Diffusion Gap: Survey Evidence from US School Principals},
  author={Campos, Christopher and Singleton, John},
  journal={Draft soon},
  abstract={We study the diffusion of artificial intelligence (AI) in US K-12 schools using original survey data from a large sample of school principals. We find that adoption has surged---going from approximately zero by late 2022 to 88\% by 2025---yet the benefits of this transformation are not reaching all students equally. We document a significant diffusion gap, indicating that a one standard deviation increase in disadvantage is associate with a 0.09-0.13$\sigma$ lower composite AI integration index capturing policy, teacher adoption, principal use, student AI encouragement, future plans, tutoring, and professional development. We also find substantial sector gaps, with private schools scoring substantially below traditional public schools (-0.42$\sigma$), while charter schools similarly show a sizable gap (-0.30$\sigma$). We find that adoption differences are primarily explained by facilitators as opposed to barriers, with principal beliefs, budget sufficiency, presence of teacher champions, and principal purchasing authority as the strongest predictors of adoption. Randomized survey incentives allow us to experimentally assess the role of selection, confirming that the diffusion gap is not an artifact of selection into responding. Our findings imply that closing the AI diffusion gap requires targeted investment in leadership development, professional development, and flexible budgets and not technology access alone.},
  selected={true}
}
