@article{aiDiffusion,
  title={The AI Diffusion Gap: Survey Evidence from US School Principals},
  author={Campos, Christopher and Singleton, John},
  journal={Draft soon},
  abstract={We study the diffusion of artificial intelligence (AI) in US K-12 schools using original survey data from a large sample of school principals. We find that adoption has surged---going from approximately zero by late 2022 to 88\% by 2025---yet the benefits of this transformation are not reaching all students equally. We document a significant \emph{diffusion gap}, indicating that a one standard deviation increase in disadvantage is associate with a 0.09-0.13$\sigma$ lower composite AI integration index capturing policy, teacher adoption, principal use, student AI encouragement, future plans, tutoring, and professional development. We also find substantial sector gaps, with private schools scoring substantially below traditional public schools (-0.42$\sigma$), while charter schools similarly show a sizable gap (-0.30$\sigma$). We find that adoption differences are primarily explained by facilitators as opposed to barriers, with principal beliefs, budget sufficiency, presence of teacher champions, and principal purchasing authority as the strongest predictors of adoption. Randomized survey incentives allow us to experimentally assess the role of selection, confirming that the diffusion gap is not an artifact of selection into responding. Our findings imply that closing the AI diffusion gap requires targeted investment in leadership development, professional development, and flexible budgets and not technology access alone.},
  selected={true}
}
